# Required for local backend + frontend
# Shared request key. Keep VITE_API_KEY equal to API_KEY.
API_KEY=dev-api-key

# Secret used to sign browser-audio session tokens.
JWT_SECRET=replace-with-a-32-character-secret

# Secret used to sign temporary PDF download URLs.
PDF_SIGNING_SECRET=replace-with-a-pdf-signing-secret

# Frontend copy of API_KEY.
VITE_API_KEY=dev-api-key

# Browser-visible backend base URL.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional local platform settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional live provider path
# Keep false for fixture-only local runs.
LIVE_PROVIDER_ENABLED=false

# Speechmatics real-time transcription key.
SPEECHMATICS_API_KEY=

# Optional custom Speechmatics websocket endpoint.
SPEECHMATICS_RT_URL=

# Thymia Sentinel API key.
THYMIA_API_KEY=

# Default Thymia Sentinel websocket endpoint.
THYMIA_SERVER_URL=wss://ws.thymia.ai

# Optional Twilio phone and SMS path
# Populate these only when testing real phone and SMS flows.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
