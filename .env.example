# Required for local backend + frontend
API_KEY=dev-api-key
JWT_SECRET=replace-with-a-32-character-secret
PDF_SIGNING_SECRET=replace-with-a-pdf-signing-secret
VITE_API_KEY=dev-api-key
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional local platform settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional live provider path
LIVE_PROVIDER_ENABLED=false
SPEECHMATICS_API_KEY=
SPEECHMATICS_RT_URL=
THYMIA_API_KEY=
THYMIA_SERVER_URL=wss://ws.thymia.ai

# Optional Twilio phone and SMS path
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
